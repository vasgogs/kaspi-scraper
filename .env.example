# Copy this file to .env and fill real values on the server.
# Never commit .env: it contains Telegram/OpenAI/SharePoint secrets.

# Telegram bot
TELEGRAM_BOT_TOKEN=0000000000:REPLACE_ME
TELEGRAM_CHAT_ID=123456789
BROADCAST_CHAT_IDS=123456789

# Mission runner: every 30 minutes by default
MISSION_APRIL_CSV="/home/vas/kaspi-scraper/миссия апрель.csv"
MISSION_APRIL_CHAT_ID=123456789
MISSION_APRIL_INTERVAL_SEC=1800
MISSION_APRIL_PREFIX=mission_april
MISSION_FILE_PREFIX=mission_april
MISSION_ADMIN_CHAT_IDS=123456789
MISSION_SUPPRESS_TELEGRAM=0
MISSION_BOT_AUTO_ENABLED=0

# Mission broadcast recipients. Use chat_id, @username or phone in international format.
TUR_TARGETS="+77770000000"
MSP_TARGETS="+77770000000"
PHARMAKOM_TARGETS="+77770000000"
ADOY_TARGETS=""
CAMPAIGN_SUMMARY_TARGETS=""

# Telethon user session for broadcasts to phones/@usernames
TELETHON_API_ID=123456
TELETHON_API_HASH=replace_me
TELETHON_PHONE="+77770000000"
TELETHON_SESSION=broadcast_session

# Optional integrations
OPENAI_API_KEY=replace_me
TAVILY_API_KEY=replace_me
SHAREPOINT_SITE_URL=https://example.sharepoint.com/sites/site
SHAREPOINT_FILE_RELATIVE_URL=/Documents/Book.xlsx
SHAREPOINT_USERNAME=user@example.com
SHAREPOINT_PASSWORD=replace_me
